# backend/.env

# ── MySQL connection ─────────────────────────────────────────────────────────
DB_HOST=localhost           # e.g. 127.0.0.1 or the host of your RDS/Container
DB_USER=root                # the user with privileges on the schema
DB_PASSWORD=        # the corresponding password
DB_NAME=kompi_cyber         # whatever database name you created (see database/schema.sql)

# ── optional extras ──────────────────────────────────────────────────────────
PORT=5000                    # port the Express app will listen on (default 5000)
JWT_SECRET=a_long_random_string